                "input": "('https://raw.githubusercontent.com/mwaskom/seaborn-data/master/titanic.csv')",
                "expected": "869"
            }
        ],
        "keywords": [],
        "function_name": "DataRead",
        "solution": [
            "import pandas as pd",
            "",
            "def DataRead(url):",
            "    df = pd.read_csv(url)",
            "    return df.isnull().sum().sum()"
